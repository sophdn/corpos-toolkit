# Canonical-ledger backup config.
#
#   mkdir -p ~/.config/corpos-toolkit
#   cp deploy/systemd/ledger-backup.env.example ~/.config/corpos-toolkit/ledger-backup.env
#   $EDITOR ~/.config/corpos-toolkit/ledger-backup.env
#
# The real file lives in ~/.config, NOT in this repo: a backup host is
# deployment config, not source. Keeping it out means this repo carries no
# infra identifiers (the commit-time pii-scan enforces that) and the public
# mirror has nothing to scrub.

# REQUIRED. Where the nightly copy is shipped: <user>@<host>:<path>
# Point it at a path the target's own backup regime already covers — the whole
# design is to inherit a proven regime rather than invent a second one.
# There is deliberately no default: unset is a hard failure, because local-only
# copies share the disk whose death is the entire scenario.
TOOLKIT_BACKUP_SHIP_TO=youruser@your-server:/home/youruser/homelab/toolkit-ledger/data/toolkit.db.snapshot

# Say local-only OUT LOUD instead (copies stay on this disk; NOT protected
# against this disk failing). Only sensible for testing.
#TOOLKIT_BACKUP_SHIP_TO=local

# --- everything below is optional; defaults are correct for this box ---

# The ledger. Resolved like go/launch.sh does when unset:
# $TOOLKIT_DB, else ${XDG_DATA_HOME:-~/.local/share}/toolkit/data/toolkit.db
#TOOLKIT_DB=

# Local copies (fast rollback cache; the long tail lives in the target's restic).
#TOOLKIT_BACKUP_DIR=

# Local retention. KEEP_MIN is a HARD FLOOR — pruning can never take the
# directory below it, whatever the ages.
#TOOLKIT_BACKUP_KEEP_DAYS=14
#TOOLKIT_BACKUP_KEEP_MIN=3

# The restore test fails if the newest copy is older than this. It is the
# deadman: a backup job that silently STOPS leaves an ancient-but-valid file
# that would otherwise keep passing.
#TOOLKIT_BACKUP_MAX_AGE_H=48
